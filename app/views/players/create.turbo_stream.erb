<% if @player.persisted? %>
  <%= turbo_stream.append "players", partial: "players/player", locals: { player: @player, tournament: @tournament } %>

  <%= turbo_stream.update "new_player_form" do %>
    <%= render "players/form", tournament: @tournament, player: Player.new %>
  <% end %>

  <%= turbo_stream.remove "no_players" %>

  <% tournament = @tournament.reload %>

  <%= turbo_stream.update "players_count" do %>
    <%= tournament.players_count %>
  <% end %>

  <%= turbo_stream.update "start_tournament_section", partial: "tournaments/start_tournament", locals: { tournament: tournament } %>

<% else %>
  <%= turbo_stream.replace "new_player_form", partial: "players/form", locals: { tournament: @tournament, player: @player } %>
<% end %>