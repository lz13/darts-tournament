<%= form_with model: player, url: tournament_players_path(tournament.share_token, tournament.admin_token) do |f| %>
  <div class="flex items-center gap-3">
    <%= f.text_field :name, class: "flex-1 rounded-lg bg-gray-800 border-gray-700 text-white placeholder-gray-500 px-4 py-3 focus:ring-2 focus:ring-emerald-500 focus:border-transparent", placeholder: "Player name/nickname", required: true, autofocus: true %>

    <%= f.submit "Add Player", class: "rounded-lg bg-emerald-600 px-6 py-3 font-semibold text-white hover:bg-emerald-500 transition-colors" %>
  </div>
<% end %>
