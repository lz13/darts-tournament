<div id="<%= dom_id(player) %>" class="flex items-center justify-between rounded-lg bg-gray-800 px-4 py-3">
  <div class="flex items-center gap-3">
    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-500/10 text-sm font-medium text-emerald-400">
      <%= player.seed_number || "-" %>
    </span>
    <span class="text-white font-medium"><%= player.name %></span>
  </div>

  <% if player.tournament.draft? %>
    <%= button_to "×", tournament_player_path(player.tournament.share_token, player.tournament.admin_token, player), method: :delete, class: "flex h-8 w-8 items-center justify-center rounded-lg text-gray-400 hover:bg-red-500/10 hover:text-red-400 transition-colors text-lg font-bold", data: { turbo_confirm: "Remove #{player.name}?"} %>
  <% end %>
</div>