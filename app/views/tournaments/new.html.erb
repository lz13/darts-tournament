<div class="mx-auto max-w-2xl px-6 py-16 lg:px-8">
  <div class="text-center mb-12">
    <h1 class="text-3xl font-bold text-white">Create New Tournament</h1>
    <p class="mt-4 text-gray-400">
      Set up your tournament details below.
    </p>
  </div>

  <%= form_with model: @tournament, class: "space-y-8" do |f| %>
    <% if @tournament.errors.any? %>
      <div class="rounded-lg bg-red-900/20 p-4 ring-1 ring-red-800">
        <h2 class="text-red-400 font-semibold mb-2">
          <%= pluralize(@tournament.errors.count, "error") %> prohibited this tournament from being saved:
        </h2>
        <ul class="text-red-300 text-sm list-disc list-inside">
          <% @tournament.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-6">
      <div>
        <%= f.label :name, "Tournament Name", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.text_field :name, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white placeholder-gray-500 px-4 py-3 focus:ring-2 focus:ring-emerald-500 focus:border-transparent", placeholder: "e.g., Friday Night Darts", required: true %>
      </div>

      <div>
        <%= f.label :legs_to_win, "Legs to Win", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.number_field :legs_to_win, min: 1, max: 20, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white placeholder-gray-500 px-4 py-3 focus:ring-2 focus:ring-emerald-500 focus:border-transparent", required: true %>
        <p class="mt-1 text-sm text-gray-500">Number of legs a player must win to advance</p>
      </div>

      <div>
        <%= f.label :seeding_method, "Seeding Method", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.select :seeding_method, options_for_select([ ["Ordered (by position)", "ordered"], ["Random", "random"], ["Manual", "manual"] ], @tournament.seeding_method), {}, class: "w-full rounded-lg bg-gray-800 border-gray-700 text-white px-4 py-3 focus:ring-2 focus:ring-emerald-500 focus:border-transparent" %>
        <p class="mt-1 text-sm text-gray-500">How players will be seeded when the tournament starts</p>
      </div>
    </div>

    <div class="flex items-center justify-between pt-6">
      <%= link_to "Cancel", root_path, class: "text-gray-400 hover:text-white transition-colors" %>
      <%= f.submit "Create Tournament", class: "rounded-lg bg-emerald-600 px-6 py-3 text-lg font-semibold text-white shadow-sm hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 transition-all hover:scale-105" %>
    </div>
  <% end %>
</div>