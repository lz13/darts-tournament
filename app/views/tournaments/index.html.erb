<div class="mx-auto max-w-4xl px-6 py-16 lg:px-8">
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-4xl font-bold text-white">Tournaments</h1>
        <p class="mt-2 text-gray-400">All your darts tournaments</p>
      </div>

      <%= link_to new_tournament_path, class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500 transition-colors" do %>
        + New Tournament
      <% end %>
    </div>
  </div>
  <% if @tournaments.empty? %>
    <div class="rounded-2xl bg-gray-900 p-12 ring-1 ring-gray-800 text-center">
      <div class="mb-4 flex justify-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-gray-800">
          <svg class="h-8 w-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
      </div>

      <h2 class="text-xl font-semibold text-white mb-2">No tournaments yet</h2>
      <p class="text-gray-500 mb-6">Create your first tournament to get started</p>

      <%= link_to "Create Tournament", new_tournament_path, class: "rounded-lg bg-emerald-600 px-6 py-3 text-lg font-semibold text-white shadow-sm hover:bg-emerald-500 transition-all hover:scale-105 inline-block" %>
    </div>
  <% else %>
    <div class="space-y-4">
      <% @tournaments.each do |tournament| %>
        <%= link_to public_tournament_path(tournament.share_token), class: "block rounded-2xl bg-gray-900 p-6 ring-1 ring-gray-800 hover:ring-emerald-500/50 transition-all" do %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500/10">
                <span class="text-lg font-bold text-emerald-400">
                  <%= tournament.name.first.upcase %>
                </span>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-white"><%= tournament.name %></h3>
                <p class="text-sm text-gray-500">
                  <%= tournament.players.count %> players • <%= tournament.legs_to_win %> legs to win
                </p>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <span class="<%= status_badge_class(tournament.status) %>">
                <%= tournament.status.titleize %>
              </span>

              <span class="text-sm text-gray-600">
                <%= time_ago_in_words(tournament.created_at) %> ago
              </span>

              <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>