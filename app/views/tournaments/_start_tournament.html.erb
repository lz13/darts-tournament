<% if tournament.draft? %>
  <div class="rounded-2xl bg-gray-900 p-6 ring-1 ring-gray-800">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-white">Ready to Start?</h2>
        <p class="text-gray-500 text-sm mt-1">
          <% if tournament.players_count < 2  %>
            Add at least 2 players to start the tournament.
          <% else %>
            Once started, players cannot be added or removed.
          <% end %>
        </p>
      </div>

      <%= button_to "start Tournament", start_tournament_path(tournament.share_token, tournament.admin_token), method: :post, class: "rounded-lg px-6 py-3 text-lg font-semibold shadow-sm transition-all hover:scale-105 #{tournament.players_count >= 2 ? 'bg-emerald-600 text-white hover:bg-emerald-500 cursor-pointer' : 'bg-gray-700 text-gray-500 cursor-not-allowed'}", disabled: tournament.players_count < 2 %>
    </div>
  </div>
<% end %>