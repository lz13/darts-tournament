<!-- Hero Section -->
<div class="relative isolate overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:top-80" aria-hidden="true">
    <div class="relative left-[calc(50%-11rem)] aspect-1155/678 w-144.5 -translate-x-1/2 rotate-30 bg-linear-to-tr from-emerald-600 to-cyan-600 opacity-20 sm:left-[calc(50%-30rem)] sm:w-288.75"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <!-- Badge -->
      <div class="mb-8 flex justify-center">
        <div class="rounded-full bg-emerald-500/10 px-3 py-1 text-sm font-medium text-emerald-400 ring-1 ring-inset ring-emerald-500/20">
          Double Elimination Brackets
        </div>
      </div>

      <!-- Heading -->
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
        Darts Tournament
        <span class="text-emerald-500">Manager</span>
      </h1>

      <!-- Description -->
      <p class="mt-6 text-lg leading-8 text-gray-300">
        Create and manage darts tournaments with ease. Set up double elimination brackets, track scores, and share live results with players and spectators.
      </p>

      <!-- CTA Buttons -->
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <%= link_to new_tournament_path, class: "rounded-lg bg-emerald-600 px-6 py-3 text-lg font-semibold text-white shadow-sm hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 transition-all hover:scale-105" do %>
          Create Tournament
          <svg class="inline-block ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        <% end %>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="mx-auto mt-24 max-w-5xl">
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Feature 1 -->
        <div class="rounded-2xl bg-gray-900 p-6 ring-1 ring-gray-800">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-500/10">
            <svg class="h-6 w-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white">Quick Setup</h3>
          <p class="mt-2 text-sm text-gray-400">
            Create a tournament in seconds. Just add player names and start playing.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="rounded-2xl bg-gray-900 p-6 ring-1 ring-gray-800">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-500/10">
            <svg class="h-6 w-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white">Double Elimination</h3>
          <p class="mt-2 text-sm text-gray-400">
            Fair brackets where every player gets a second chance before elimination.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="rounded-2xl bg-gray-900 p-6 ring-1 ring-gray-800">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-500/10">
            <svg class="h-6 w-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white">Share Live</h3>
          <p class="mt-2 text-sm text-gray-400">
            Share a link so everyone can follow the bracket in real-time.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Turbo Frame Section Test -->
<div class="bg-gray-900 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-2xl font-bold text-white mb-8 text-center">Tech Stack Verification</h2>

      <div class="grid gap-6 sm:grid-cols-2">
        <!-- Stimulus Test -->
        <div class="rounded-xl bg-gray-800 p-6 ring-1 ring-gray-700" data-controller="hello">
          <h3 class="text-lg font-semibold text-white mb-4">Stimulus Test</h3>
          <div class="space-y-4">
            <input
              type="text"
              data-hello-target="name"
              class="w-full rounded-lg bg-gray-700 border-gray-600 text-white placeholder-gray-400 px-4 py-2 focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
            >
            <button
              data-action="click->hello#greet"
              class="w-full rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-500 transition-colors"
            >
              Test Stimulus
            </button>
            <p class="text-gray-400 text-sm">
              Output: <span data-hello-target="output" class="text-emerald-400 font-medium"></span>
            </p>
          </div>
        </div>

        <!-- Turbo Test -->
        <%= turbo_frame_tag "turbo-test" do %>
          <div class="rounded-xl bg-gray-800 p-6 ring-1 ring-gray-700">
            <h3 class="text-lg font-semibold text-white mb-4">Turbo Frame Test</h3>
            <div class="space-y-4">
              <p class="text-gray-400 text-sm">
                Current time: <span class="text-emerald-400 font-medium"><%= Time.current.strftime("%H:%M:%S") %></span>
              </p>
              <%= link_to "Refresh Time (Turbo)", root_path, class: "block w-full text-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-500 transition-colors", data: { turbo_frame: "turbo-test" } %>
              <p class="text-gray-500 text-xs">
                Click to refresh only this frame (page won't (shouldn't) reload).
              </p>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Confirmation -->
      <div class="mt-8 rounded-xl bg-emerald-900/20 p-4 ring-1 ring-emerald-800">
        <p class="text-sm text-emerald-300 text-center">
          If you can enter a name and see a greeting, <strong>Stimulus is working</strong>.
          <br>
          If clicking "Refresh Time" updates only the time without page reload, <strong>Turbo Frame is working</strong>.
        </p>
      </div>
    </div>
  </div>
</div>